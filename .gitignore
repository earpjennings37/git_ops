# Terraform
# ----------------------------------------
.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Terraform plans
*.tfplan
*.plan

# Local-only variable files (never commit secrets)
*.tfvars
*.tfvars.json
*.auto.tfvars
*.auto.tfvars.json
terraform.tfvars
terraform.tfvars.json
*state.config

# Terraform override files (local only)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI config
.terraformrc
terraform.rc

# Commit this for reproducible provider versions
# (HCP Terraform expects it)
# DO NOT ignore:
# .terraform.lock.hcl

